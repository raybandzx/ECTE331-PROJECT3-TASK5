public class SafetyMonitor extends Thread {

    private MotorControl motor;

    public SafetyMonitor(MotorControl motor) {
        this.motor = motor;
        setName("Safety Monitor");
        setPriority(Thread.MAX_PRIORITY);
    }

    @Override
    public void run() {
        while (true) {

            System.out.println(getName() + " is running.");

            long start = System.currentTimeMillis();

            motor.useMotor(this);

            long end = System.currentTimeMillis();

            System.out.println(">>> " + getName() + " WAITED " + (end - start) + " ms for the motor");

            try {
                Thread.sleep(1000);
            } catch (InterruptedException e) {
                e.printStackTrace();
            }
        }
    }
}
